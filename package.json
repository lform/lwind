{
	"name": "@lform/lwind",
	"version": "4.1.0",
	"description": "Customized tailwind framework",
	"main": "package.json",
	"private": false,
	"scripts": {
		"dev": "npx @tailwindcss/cli -i ./css/main.css -o ./dist/app.css",
		"watch": "npx @tailwindcss/cli -i ./css/main.css -o ./dist/app.css --watch",
		"prod": "NODE_ENV=production npx @tailwindcss/cli -i ./css/main.css -o ./dist/app.min.css --minify",
		"demo": "mkdir -p ./dist && npm run dev && cp ./demo/kitchen-sink.html ./dist/kitchen-sink.html"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lform/lwind.git"
	},
	"bugs": {
		"url": "https://github.com/lform/lwind/issues"
	},
	"homepage": "https://github.com/lform/lwind#readme",
	"keywords": [],
	"author": "Lform Design",
	"license": "ISC",
	"dependencies": {
		"@tailwindcss/cli": "^4.1.3",
		"@tailwindcss/forms": "^0.5.7",
		"tailwindcss": "^4.1.1"
	}
}
